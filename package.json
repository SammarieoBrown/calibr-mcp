{
  "name": "@calibr/mcp",
  "version": "0.1.0",
  "description": "MCP server for the Calibr credit risk platform",
  "type": "module",
  "bin": {
    "calibr-mcp": "./dist/index.js"
  },
  "main": "./dist/server.js",
  "exports": {
    ".": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "peerDependencies": {
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "msw": "^2.7.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0",
    "zod": "^3.25.0"
  },
  "keywords": [
    "mcp",
    "calibr",
    "credit-risk",
    "scorecard"
  ],
  "license": "MIT"
}
